			)
			(justify left)
		)
	)
	(gr_text "1. FABRICATE PER IPC-6011 & IPC-6012 CLASS 2, LATEST REVISION.\n\n2. MATERIAL: LAMINATE PER IPC-4101/26 OR /126 - FR4\n   COPPER WEIGHT = 1 OZ; INNER COPPER WEIGHT = 0.5 OZ\n\n3. SURFACE FINISH: HASL\n\n4. SOLDER MASK GLOSSY OR SEMI-GLOSS LPI PER IPC-SM-840 TYPE H.\n\n5. SILKSCREEN NON-CONDUCTIVE EPOXY INK. CLIP SILKSCREEN AS NEEDED TO PREVENT DEPOSITION \n   ON ANY SOLDERABLE SURFACE. SILKSCREEN OVER TENTED VIAS IS ACCEPTABLE.\n\n6. FRONT PASTE PLATE INCLUDES ALL FOUR PCB MOUNTING HOLES. THIS IS INTENTIONAL AND \n   FOR STENSIL USE PURPOSES.\n\n7. RoHS AND REACH COMPLIANCE."
		(at 160.27 84.21 0)
		(layer "Dwgs.User")
		(uuid "44da24f1-3d4b-4ab8-ba2d-f2d387ef6dc2")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.15)
			)
			(justify left bottom)
		)
	)
